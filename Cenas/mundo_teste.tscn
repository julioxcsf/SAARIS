# Função que faz tudo: Calcula Tamanho + Instancia + Posiciona + Handshake
func _create_ris_complete(pos_clique: Vector3):
	# 1. CÁLCULO FÍSICO (Baseado na Frequência e Ganho Desejado)
	# Usa a função auxiliar que criamos antes
	var props = _calculate_ris_properties(ris_target_gain_db, frequencia_mhz)
	
	# Atualiza as variáveis globais de simulação
	ris_physical_area_m2 = props[\"physical_area\"]
	ris_gain_db = props[\"real_gain_db\"]
	
	print(\"Criando RIS em: %s | Tamanho: %dx%d células\" % [pos_clique, props[\"N\"], props[\"M\"]])
	
	# 2. INSTANCIA O OBJETO
	var novo_ris = ris_scene.instantiate()
	add_child(novo_ris)
	
	# 3. APLICA A ESCALA VISUAL
	# O cubo padrão do Godot tem 1x1x1m. Scale ajusta para o tamanho real calculado.
	novo_ris.scale = Vector3(props[\"width_m\"], props[\"height_m\"], 0.05)
	
	# 4. POSICIONA ONDE VOCÊ CLICOU
	# Adicionamos +altura/2 no Y para ele não nascer enterrado no chão
	var altura_do_centro = max(1.5, props[\"height_m\"] / 2.0)
	novo_ris.global_position = pos_clique + Vector3(0, altura_do_centro, 0)
	
	# 5. REGISTRA NO SISTEMA
	_active_ris_nodes.append(novo_ris)
	var novo_index = _active_ris_nodes.size() - 1
	
	novo_ris.name = \"RIS_%d\" % novo_index
	novo_ris.add_to_group(\"reflectors\")
	active_ris = novo_ris # Define como o RIS ativo atual
	
	# 6. ORIENTAÇÃO AUTOMÁTICA (Opcional, mas útil)
	# Se já tiver um alvo, já olha para ele
	if not active_targets.is_empty():
		_orient_ris_automatically()
	
	# 7. HANDSHAKE (Avisa a Interface)
	var display_name = \"RIS %d (%.0f MHz | %dx%d)\" % [novo_index, frequencia_mhz, props[\"N\"], props[\"M\"]]
	emit_signal(\"ris_created_success\", novo_index, display_name)

# Chamado quando a Interface pede \"request_delete_ris\"
func _on_interface_request_delete_ris(index: int):
	print(\"Motor: Recebi pedido de deletar RIS %d.\" % index)
	
	# Validação de Segurança (O Motor protege contra crash)
	if index < 0 or index >= _active_ris_nodes.size():
		push_error(\"Motor: Interface pediu para deletar índice inválido: %d\" % index)
		return

	# 1. Pega o objeto
	var ris_node = _active_ris_nodes[index]
	
	# 2. Remove do Mundo
	if is_instance_valid(ris_node):
		ris_node.queue_free()
	
	# 3. Remove da Lista do Motor
	_active_ris_nodes.remove_at(index)
	
	# 4. HANDSHAKE: Avisa a interface para atualizar a lista dela
	emit_signal(\"ris_deleted_success\", index)

func _on_interface_request_remove_target(index: int):
	if index < 0 or index >= active_targets.size(): return

	var alvo = active_targets[index]
	if is_instance_valid(alvo):
		alvo.queue_free()

	active_targets.remove_at(index)

	# Recalcula pesos
	var n = float(active_targets.size())
	active_ris_weight = 1.0 / n if n > 0 else 0.0

	# Atualiza visualização se necessário
	if show_ris_effect: _refresh_ris_visualization()
	print(\"Motor: Alvo %d removido.\" % index)

# Chamado quando a Interface (Botão + do Target) pede para posicionar um alvo
func _on_interface_request_place_target():
	print(\"Motor: Recebi pedido para posicionar Alvo. Clique no cenário.\")
	# Muda o modo do mouse para \"Colocando Alvo\"
	current_input_mode = InputMode.PLACING_TARGET
"

