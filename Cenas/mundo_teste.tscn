		#active_ris = ris_scene.instantiate()
		#add_child(active_ris)
		#active_ris.add_to_group(\"reflectors\") # Importante para o futuro
#
	## Levanta um pouco (1.5m) para não ficar enterrado no chão
	#active_ris.global_position = pos + Vector3(0, 4.9, 0)
	#print(\"RIS posicionado em: \", active_ris.global_position)

# 4. Orientação Inteligente (Lei da Reflexão)
func _orient_ris_automatically():
	if not active_ris: return
	if _tx_nodes.is_empty() or active_targets.is_empty():
		return
		
	# Usa o primeiro TX como referência
	var tx_ref = _tx_nodes[0]
	var ris_pos = active_ris.global_position
	var tx_pos = tx_ref.global_position

	# 1. Calcula o Ponto Médio (Centróide) de todos os alvos
	var average_target_pos = Vector3.ZERO
	for alvo in active_targets:
		average_target_pos += alvo.global_position
	
	average_target_pos /= float(active_targets.size())
	
	# 2. Vetores de direção (Normalizados)
	var dir_to_tx = (tx_pos - ris_pos).normalized()
	var dir_to_centroid = (average_target_pos - ris_pos).normalized()

	# 3. A Normal Ideal (Bissetriz entre TX e o Centróide dos Alvos)
	var ideal_normal = (dir_to_tx + dir_to_centroid).normalized()

	# 4. Orienta o RIS
	active_ris.look_at(ris_pos + ideal_normal, Vector3.UP)

	print(\"RIS reorientado para o centróide de %d alvos.\" % active_targets.size())


# Cria ou move o RIS (Caixa Azul Semitransparente)
func _spawn_ris(pos: Vector3):
	if active_ris == null:
		active_ris = ris_scene.instantiate()
		add_child(active_ris)
		active_ris.add_to_group(\"reflectors\")
		
		# --- ADICIONA O VOLUME VISUAL ---
		var mesh_instance = active_ris.get_node(\"MeshInstance3D\") # Assumindo que sua cena tem esse nome
		if mesh_instance:
			var material = StandardMaterial3D.new()
			#material.transparency = BaseMaterial3D.TRANSPARENCY_ALPHA
			#material.albedo_color = Color(0.0, 0.5, 1.0, 0.3) # Azul 30% opaco
			#mesh_instance.material_override = material
			# Aumenta um pouco a escala visual para parecer uma \"zona\"
			mesh_instance.scale = Vector3(20.0, 20.0, 10.0) 

	active_ris.global_position = pos + Vector3(0, 4.9, 0)
	print(\"Zona do RIS definida em: \", active_ris.global_position)

# Cria ou move o Alvo (Caixa Verde Semitransparente)
# Adiciona um novo alvo e recalcula o peso
# Adiciona um novo alvo e recalcula o peso
func _spawn_target_visual(pos: Vector3):
	var novo_alvo = MeshInstance3D.new()
	var mesh = BoxMesh.new()
	
	# USANDO SUAS NOVAS VARIÁVEIS AQUI:
	mesh.size = Vector3(target_width_x, 2.0, target_length_z) 
	
	novo_alvo.mesh = mesh
	
	# Centraliza
	novo_alvo.global_position = pos + Vector3(0, 1.0, 0)
	novo_alvo.rotation_degrees.y = target_rotation_y # Já nasce rodado
	
	# Material Verde Semitransparente
	var material = StandardMaterial3D.new()
	material.transparency = BaseMaterial3D.TRANSPARENCY_ALPHA
	material.albedo_color = Color(0.0, 1.0, 0.0, 0.3)
	novo_alvo.material_override = material
	
	add_child(novo_alvo)
	active_targets.append(novo_alvo)
	
	
	# Recalcula pesos
	var n = float(active_targets.size())
	active_ris_weight = 1.0 / n if n > 0 else 0.0
	
	# --- ADICIONE ISSO NO FINAL ---
	# Avisa a interface para botar o nome na lista
	var interface = get_node_or_null(interface_manager_path)
	if interface and interface.has_method(\"add_target_to_ui_list\"):
		var index = active_targets.size() - 1
		interface.add_target_to_ui_list(\"Alvo %d\" % index)
	
	# Se já tiver RIS, atualiza o tamanho da mancha vermelha
	_update_target_visuals() 
	
	print(\">> ALVO POSICIONADO! Para fixar: _spawn_target_visual(Vector3(%.3f, %.3f, %.3f))\" % [pos.x, pos.y, pos.z])

func _update_target_visuals():
	if active_targets.is_empty(): return
	
	for alvo in active_targets:
		# Atualiza o tamanho da Mesh (Caixa)
		# Mantemos o Y (altura) fixo em 2.0m para não afundar no chão
		if alvo.mesh is BoxMesh:
			alvo.mesh.size = Vector3(target_width_x, 2.0, target_length_z)
		
		# Atualiza a Rotação
		alvo.rotation_degrees.y = target_rotation_y
	
	# TRUQUE DE MESTRE:
	# Atualiza o raio da física automaticamente para cobrir a nova área da caixa
	# Assim você não precisa ficar ajustando o \"Target Spot Radius\" na mão
	target_spot_radius = max(target_width_x, target_length_z) / 2.0
	
	# Se a simulação já rodou, atualiza o desenho vermelho
	if show_ris_effect:
		_refresh_ris_visualization()


