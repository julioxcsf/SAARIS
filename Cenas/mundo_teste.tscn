func _verifica_LOS(origin: Vector3, target_pos: Vector3, exclude_list: Array): # TESTANDO 27/01/26 nova função
	# O raio vai da origem até o alvo. 
	# Como o alvo (chão) está na exclude_list, se não houver obstáculo,
	# intersect_ray retornará vazio (Dicionário {}). Isso significa LOS LIVRE.
	var query = PhysicsRayQueryParameters3D.create(origin, target_pos)
	query.exclude = exclude_list
	
	# OTIMIZAÇÃO: Não precisamos mais checar colisao com Area3D se for só prédio
	query.collide_with_areas = false 
	
	return _space_state.intersect_ray(query)

func _verifica_1_zona_fresnel(direction: Vector3, origin: Vector3, target_pos: Vector3, exclude_list: Array):
	# Verifica obstrução na Zona de Fresnel (Cilindro)
	var vec_target_dist = target_pos - origin
	var target_dist = vec_target_dist.length()
	var fresnel_radius = 0.5 * sqrt(lambda_m * target_dist)
	if fresnel_radius < 0.1: fresnel_radius = 0.1 # acho que vale apena ignorar se for pequeno.. usar como LOS mesmo
	
	var params = PhysicsShapeQueryParameters3D.new()
	var shape = CylinderShape3D.new()
	shape.height = target_dist
	shape.radius = fresnel_radius
	params.shape = shape
	
	# base que olha para mid_point + direction
	var mid_point = origin + direction * (target_dist / 2.0)
	var transform = Transform3D().looking_at(mid_point + direction, Vector3.UP)
	transform.origin = mid_point
	# Não rode a base com PI/2; ao invés disso, alinhe o eixo Y do cilindro com 'direction'
	# Uma maneira simples: criar basis que alinha Y com direction:
	var up = direction.normalized()
	var right = up.cross(Vector3(0, 1, 0))
	if right.length() < 0.001:
		right = up.cross(Vector3(1, 0, 0))
	var forward = right.cross(up).normalized()
	var basis = Basis()
	basis.x = right.normalized()
	basis.y = up.normalized()
	basis.z = forward.normalized()
	transform.basis = basis
	params.transform = transform
	params.exclude = exclude_list
	
	return _space_state.intersect_shape(params, 8)

func _calculate_pixel_signal(origin: Vector3, direction: Vector3, target_dist: float, current_watts: float, exclude_list: Array, depth: int):
	# Condição de Parada
	# var min_watts = dbm_to_watts(min_sinal_dbm) # está no start_simulation()
	if depth > max_reflections or current_watts < min_watts:
		return

	# var lambda_m = get_lambda_m() # está no start_simulation()
	var target_pos = origin + direction * target_dist
	
	# ETAPA 1: LOS? (Linha Reta)
	var result_los = _verifica_LOS(origin, target_pos, exclude_list)
	
	# --- IF LOS BLOQUEADO ---
	if not result_los.is_empty():
		var hit_pos = result_los[\"position\"]
		var hit_normal = result_los[\"normal\"]
		var hit_rid = result_los[\"rid\"]
		
		# A) REFLEXÃO DIRETA (Recursão)
		var dist_to_hit = origin.distance_to(hit_pos)
		var loss_to_hit = pow(lambda_m / (4.0 * PI * dist_to_hit), path_loss_exponent)
		var watts_at_hit = current_watts * loss_to_hit
		
		var reflect_dir = direction.bounce(hit_normal).normalized()
		var reflection_loss = db_to_linear(-reflection_loss_db)
		var new_tx_watts = watts_at_hit * reflection_loss
		
		var new_dist = 5000.0 # Alcance da reflexão
		var new_exclude = exclude_list.duplicate()
		new_exclude.append(hit_rid)
		
		# Chamada Recursiva para o Raio Refletido
		_calculate_pixel_signal(hit_pos + hit_normal * offset_colider, reflect_dir, new_dist, new_tx_watts, new_exclude, depth + 1)
		
		# B) CÁLCULO DE PERDA POR DIFRAÇÃO (DEYGOUT)
		
		# Calcula a perda em dB usando o algoritmo de Deygout
		var diffraction_loss_db = _calculate_deygout_path_recursive(origin, target_pos, exclude_list)
		var diff_loss_linear = db_to_linear(-diffraction_loss_db)
		
		# Calcula o sinal final no pixel (FSPL Total + Perda Difração)
		var fspl_total = pow(lambda_m / (4.0 * PI * target_dist), path_loss_exponent)
		var final_watts_diffracted = current_watts * fspl_total * diff_loss_linear
		
		_accumulate_power_at_pos(target_pos, final_watts_diffracted)

	# --- IF LOS LIVRE ---
	else:
		var collisions = _verifica_1_zona_fresnel(direction ,origin, target_pos, exclude_list)
		
		var fresnel_obstructed = false
		for col in collisions:
			if col[\"rid\"] != _chao_static_body.get_rid():
				fresnel_obstructed = true
				break
		
		var fspl = pow(lambda_m / (4.0 * PI * target_dist), path_loss_exponent)
		var base_watts = current_watts * fspl
		
		if not fresnel_obstructed:
			# Caminho Limpo
			_accumulate_power_at_pos(target_pos, base_watts)
		else:
			var diffraction_loss_db = _calculate_deygout_path_recursive(origin, target_pos, exclude_list)
			_accumulate_power_at_pos(target_pos, base_watts * diffraction_loss_db)
	
	if ris_enabled:
		_calculate_ris_reflection(origin, direction, target_dist, current_watts, exclude_list)


# Função auxiliar para pegar RIDs de todos os filhos e netos (Recursiva)
func _get_all_rids_recursive(node: Node, list: Array):
	if node is CollisionObject3D:
		list.append(node.get_rid())
	
	for child in node.get_children():
		_get_all_rids_recursive(child, list)

func _calculate_ris_reflection(tx_pos: Vector3, dir_to_pixel: Vector3, dist_tx_pixel: float, tx_watts: float, exclude_list: Array):
	# Se não tiver alvo definido, ou se o botão \"Ativar RIS\" estiver desligado, sai.
	#if target_point == Vector3.ZERO: return

	var ris_pos = active_ris.global_position
	# Posição onde este pixel está no mundo
	var pixel_pos = tx_pos + dir_to_pixel * dist_tx_pixel
	
	# --- FILTRO 1: ÁREA DO ALVO (O \"Spotlight\") ---
	# Aumentei para 25 metros para garantir que você veja, mesmo se clicar meio longe
	var raio_de_atuacao = 25.0 
	
	#if pixel_pos.distance_to(target_point) > raio_de_atuacao:
	#	return

	# --- MODO DORMIR: SEM RAYCASTS ---
	# Removi todos os 'intersect_ray'. Nada bloqueia o sinal agora.
	
	# --- CÁLCULO DIRETO ---
	var dist_tx_ris = tx_pos.distance_to(ris_pos)
	var dist_ris_pixel = ris_pos.distance_to(pixel_pos)
	var total_dist = dist_tx_ris + dist_ris_pixel
	
	# var lambda_m = RFMath.get_lambda_m(frequencia_mhz) # TESTANDO 27/01/26
	
	# Perda de Espaço Livre
	var path_loss = pow(lambda_m / (4.0 * PI * total_dist), 2.0)
	
	# Ganho (Seu ganho de 100dB vai fazer brilhar como o sol)
	var ris_gain_linear = db_to_linear(ris_gain_db)
	
	var received_watts_from_ris = tx_watts * path_loss * ris_gain_linear
	
	# PINTA!
	_accumulate_power_at_pos(pixel_pos, received_watts_from_ris)


func _pixel_to_world(px: Vector2i) -> Vector3:
	var uv_x = ((float(px.x) + 0.5) / resolution.x) - 0.5 #+ 0.5/resolution.x
	var uv_y = ((float(px.y) + 0.5) / resolution.y) - 0.5 #+ 0.5/resolution.y
	var local_x = uv_x * _plane_size.x
	var local_z = uv_y * _plane_size.y
	var world_pos = _chao_parent.to_global(Vector3(local_x, 0, local_z))
	world_pos.y -= 0.05
	return world_pos
	#return _chao_parent.to_global(Vector3(local_x, 0, local_z))

func _accumulate_power_at_pos(global_pos: Vector3, watts: float):
	var local_pos = _chao_parent.to_local(global_pos)
	var uv_x = (local_pos.x / _plane_size.x) + 0.5
	var uv_y = (local_pos.z / _plane_size.y) + 0.5
	var px = int(uv_x * resolution.x)
	var py = int(uv_y * resolution.y)
	
	if px >= 0 and px < resolution.x and py >= 0 and py < resolution.y:
		var idx = py * resolution.x + px
		_power_map_watts[idx] += watts

func update_visual_texture_from_watts():
	for i in range(_power_map_watts.size()):
		var w = _power_map_watts[i]
		if w <= 0.0: continue
		var dbm = RFMath.watts_to_dbm(w)
		if dbm > min_sinal_dbm:
			var y = int(i / resolution.x)
			var x = int(i % resolution.x)
			result_image.set_pixel(x, y, Color(dbm, 0, 0)) 
	result_texture.update(result_image)


# NOVO: Helper para pegar o AABB (Bounding Box) de um obstáculo
# CORRIGIDO (V5) para usar a lógica correta: global_transform * get_aabb()
func _calculate_aabb_logic(collider_body: PhysicsBody3D) -> AABB:
	
	# Pega o nó PAI do corpo de colisão.
	var parent_node = collider_body.get_parent()
	
	if not parent_node:
		push_error(\"Obstáculo %s não tem um nó PAI!\" % collider_body.name)
		return AABB()

	# --- Estratégia 1: O PAI é a Malha? (A SUA ESTRUTURA!) ---
	if parent_node is MeshInstance3D:
		# SUCESSO! Esta é a sua estrutura.
		# CORREÇÃO AQUI: Pega a AABB local e transforma para global
		return parent_node.global_transform * parent_node.get_aabb()

	# --- Estratégia 2: A Malha é \"Irmã\"? (Estrutura padrão do Godot) ---
	# (Se o pai for um Node3D genérico, procuramos um \"irmão\" MeshInstance)
	for child in parent_node.get_children():
		if child is MeshInstance3D:
			# Achou! A \"irmã\" MeshInstance3D tem a AABB.
			# CORREÇÃO AQUI: Pega a AABB local e transforma para global
			return child.global_transform * child.get_aabb()

	# --- Estratégia 3: A Malha é \"Filha\"? (Estrutura incomum) ---
	for child in collider_body.get_children():
		if child is MeshInstance3D:
			# Achou! A \"filha\" MeshInstance3D tem a AABB.
			# CORREÇÃO AQUI: Pega a AABB local e transforma para global
			return child.global_transform * child.get_aabb()

	# --- Falha Total ---
	# Se chegou aqui, não achou a MeshInstance3D em lugar nenhum.
	for child in collider_body.get_children():
		if child is CollisionShape3D:
			if child.shape and child.shape.has_method(\"get_aabb\"):
				# Esta lógica já estava correta (pega a AABB da shape)
				var local_aabb = child.shape.get_aabb()
				return child.global_transform * local_aabb
			else:
				# Este é o erro que você está vendo!
				push_error(\"FALHA AABB: Obstáculo %s (Pai: %s) usa Shape (ConcavePolygon) sem .get_aabb(). E não foi encontrada nenhuma MeshInstance3D (como pai, irmã ou filha). Verifique a estrutura da cena.\" % [collider_body.name, parent_node.name])
				return AABB()
	
	push_error(\"FALHA CRÍTICA AABB: Obstáculo %s não tem MeshInstance3D nem CollisionShape3D.\" % collider_body.name)
	return AABB()



# A implementação recursiva do Método Deygout - HÍBRIDA (AABB Limits + Binary Search Scanner)
func _calculate_deygout_path_recursive(path_start: Vector3, path_end: Vector3, exclude_list: Array, depth: int = 0) -> float:
	# Trava de segurança para recursão infinita (Crash protection)
	if depth > 5:
		return 100.0 # Perda máxima se ficar preso em loop

	# 1. Traça o raio principal (Linha de Visada)
	var query = PhysicsRayQueryParameters3D.create(path_start, path_end)
	query.exclude = exclude_list
	var result = _space_state.intersect_ray(query)

	# 2. Caso Base: Caminho livre, sem perda
	if result.is_empty():
		return 0.0 

	# 3. Colisão detectada
	var obstacle_body = result.collider
	var hit_pos = result.position
	var obstacle_rid = obstacle_body.get_rid()
	
	# Pega o AABB do cache (ou calcula na hora se falhar) para usar como LIMITE DE BUSCA
	var aabb = AABB()
	if _aabb_cache.has(obstacle_rid):
		aabb = _aabb_cache[obstacle_rid]
	else:
		# Fallback se não estiver cacheado (dinâmico ou erro)
		aabb = _calculate_aabb_logic(obstacle_body)

	# Se falhar o AABB, usamos um tamanho padrão de segurança (ex: 100m)
	var safe_radius = 100.0
	var safe_top_y = hit_pos.y + 100.0
	
	if aabb.size != Vector3.ZERO:
		# AABB define os limites máximos onde a aresta PODE estar
		safe_radius = max(aabb.size.x, aabb.size.z) * 1.5 # Um pouco de folga
		safe_top_y = aabb.end.y + 0.5 # Topo do AABB + folga
	
	# --- 4. O SCANNER DE ARESTAS (A mágica acontece aqui) ---
	
	# Vetores de direção para buscar as bordas
	var path_dir = (path_end - path_start).normalized()
	var up_vec = Vector3.UP
	# Vetor \"Direita\" relativo à visão (produto vetorial)
	var right_vec = path_dir.cross(up_vec).normalized()
	# Vetor \"Esquerda\" é o oposto
	var left_vec = -right_vec
	
	# A) Busca Borda SUPERIOR (Difração Vertical)
	# Limite da busca: Do ponto de batida (hit_pos) até o topo do AABB
	var dist_to_top = safe_top_y - hit_pos.y
	if dist_to_top < 0.1: dist_to_top = 1.0 # Segurança mínima
	
	var edge_point_top = _binary_search_edge(
		path_start, 
		hit_pos, 
		up_vec, 
		dist_to_top, 
		obstacle_rid
	)

	# B) Busca Borda ESQUERDA
	var edge_point_left = _binary_search_edge(
		path_start, 
		hit_pos, 
		left_vec, 
		safe_radius, 
		obstacle_rid
	)

	# C) Busca Borda DIREITA
	var edge_point_right = _binary_search_edge(
		path_start, 
		hit_pos, 
		right_vec, 
		safe_radius, 
		obstacle_rid
	)

	# --- 5. Calcular Fresnel (v) para os 3 pontos encontrados ---
	# Nota: Como o scanner retorna o ponto exato da borda, usamos a geometria direta
	
	# Distâncias da LOS
	var d1 = path_start.distance_to(hit_pos)
	var d2 = hit_pos.distance_to(path_end)
	# var lambda_m = RFMath.get_lambda_m(frequencia_mhz) # TESTANDO 27/01/26
	
	# Ponto ideal da LOS se não houvesse prédio
	var los_pos_ideal = path_start.lerp(path_end, d1 / (d1 + d2))
	
	# Calcula o 'h' (distância da borda encontrada até a linha de visada ideal)
	var h_top = edge_point_top.distance_to(los_pos_ideal)
	# Verificação de sinal: Se a borda está abaixo da LOS, h é negativo (mas aqui assumimos obstrução, então positivo)
	# Simplificação: distancia euclidiana direta é robusta.
	
	var h_left = edge_point_left.distance_to(los_pos_ideal)
	var h_right = edge_point_right.distance_to(los_pos_ideal)

	# Calcula perdas
	var loss_top = RFMath.calculate_knife_edge_loss_db(RFMath.calculate_diffraction_parameter_v(h_top, d1, d2, lambda_m))
	var loss_left = RFMath.calculate_knife_edge_loss_db(RFMath.calculate_diffraction_parameter_v(h_left, d1, d2, lambda_m))
	var loss_right = RFMath.calculate_knife_edge_loss_db(RFMath.calculate_diffraction_parameter_v(h_right, d1, d2, lambda_m))

	# --- 6. Escolher o Melhor Caminho (Menor Perda) ---
	var best_loss = loss_top
	var next_start_point = edge_point_top
	
	if loss_left < best_loss:
		best_loss = loss_left
		next_start_point = edge_point_left
	
	if loss_right < best_loss:
		best_loss = loss_right
		next_start_point = edge_point_right
		
	# --- 7. Recursão ---
	# Offset de segurança para o raio não bater na mesma quina
	var dir_to_end = (path_end - next_start_point).normalized()
	next_start_point += dir_to_end * 0.1 # Avança 10cm na direção do destino
	
	var new_exclude = exclude_list.duplicate()
	new_exclude.append(obstacle_rid)
	
	var recursive_loss = _calculate_deygout_path_recursive(next_start_point, path_end, new_exclude, depth + 1)
	
	return best_loss + recursive_loss

# Função Genérica de Busca Binária por Aresta
# Retorna: O ponto no espaço (Vector3) onde o obstáculo termina e o ar começa.
func _binary_search_edge(origin: Vector3, start_point: Vector3, direction_vec: Vector3, max_dist: float, target_rid: RID) -> Vector3:
	
	var low = 0.0
	var high = max_dist
	
	# Precisão: 8 iterações.
	# Para 100m, precisão de ~40cm. Para 10m, precisão de ~4cm.
	# Pode aumentar para 12 se quiser precisão de milímetros.
	var iterations = 8 
	
	# O ponto \"seguro\" de colisão é o start_point (low=0)
	# O ponto \"provavelmente livre\" é start_point + direction * high
	
	for i in range(iterations):
		var mid = (low + high) / 2.0
		var test_point = start_point + direction_vec * mid
		
		# Atira um raio da ORIGEM (TX) até o ponto de teste
		var query = PhysicsRayQueryParameters3D.create(origin, test_point)
		# Não excluímos o target_rid, pois queremos saber se batemos NELE
		var result = _space_state.intersect_ray(query)
		
		var hit_target = false
		if not result.is_empty():
			if result.collider.get_rid() == target_rid:
				hit_target = true
		
		if hit_target:
			# Se bateu no mesmo obstáculo, a borda está mais longe.
			# O ponto 'mid' ainda está obstruído.
			low = mid
		else:
			# Se não bateu (ou bateu em outra coisa lá trás), estamos no ar livre (ou passamos da borda).
			# A borda está mais perto.
			high = mid
			
	# O resultado final é o ponto 'high' (o primeiro ponto considerado \"livre\")
	return start_point + direction_vec * high

# FUNCOES DE DESENHO E PINTURA =====================================================================

# Converte a posição 3D para o pixel da textura e pinta
func _paint_pixel_at_global_pos(global_pos: Vector3, signal_dbm: float):
	if signal_dbm < min_sinal_dbm:
		return # Sinal muito fraco, não pinta
		
	# 1. Converte a posição global do \"pouso\" para a posição local do plano
	#var local_pos = _chao_parent.to_local(global_pos)
	var local_pos = global_pos
	
	# 2. Converte a posição local (-size/2 a +size/2) para UV (0.0 a 1.0)
	var uv_x = (local_pos.x*+1.0 / _plane_size.x) + 0.5
	var uv_y = (local_pos.z*+1.0 / _plane_size.y) + 0.5
	
	# 3. Converte UV para coordenadas de pixel (0 a resolution)
	var px = int(uv_x * resolution.x)
	var py = int(uv_y * resolution.y)

	# 4. Checagem de segurança (se o raio pousou fora do plano)
	if px < 0 or px >= resolution.x or py < 0 or py >= resolution.y:
		Manager.log_error(\"Pintura REJEITADA. Raio pousou fora do mapa. global_pos: %s, px: %s, py: %s\" % [global_pos, px, py])
		return

	# 5. Pinta o pixel (apenas se o novo sinal for mais forte)
	var current_signal = result_image.get_pixel(px, py).r#.r??
	if signal_dbm > current_signal:
		#Manager.log_debug(\"Pintura ACEITA. Posição: %s, Pixel: (%s, %s), Sinal: %s\" % [global_pos, px, py, signal_dbm],\"lime\")
		result_image.set_pixel(px, py, Color(signal_dbm, 0, 0))


# --- FUNÇÃO DE DEBUG PARA PINTAR UM RETÂNGULO ---
#
# Pinta um retângulo no CHÃO usando coordenadas de MUNDO (global)
# xi, xo: início e fim do retângulo no eixo X global
# yi, yo: início e fim do retângulo no eixo Z global (você chamou de Y)
# potencia: o valor de dBm para pintar
#
func _debug_paint_world_rectangle(xi: float, xo: float, yi: float, yo: float, potencia: float):
	
	Manager.log_debug(\"Debug: Pintando retângulo de MUNDO de (x:%s, z:%s) até (x:%s, z:%s)\" % [xi, yi, xo, yo])

	# Checagem de segurança
	if _plane_size.x == 0 or _plane_size.y == 0:
		Manager.log_debug(\"Erro de Debug: _plane_size é zero!\")
		return
		
	# O \"passo\" do loop. Vamos usar o tamanho de um pixel no mundo.
	var step_x = _plane_size.x / resolution.x
	var step_z = _plane_size.y / resolution.y # _plane_size.y é o Z do PlaneMesh

	var x_start = min(xi, xo)
	var x_end = max(xi, xo)
	var z_start = min(yi, yo) # Usando yi/yo como Z
	var z_end = max(yi, yo)   # Usando yi/yo como Z

	var current_x = x_start
	while current_x < x_end:
		var current_z = z_start
		while current_z < z_end:
			
			# Cria o ponto no chão em coordenadas globais
			var global_pos = Vector3(current_x, 0.0, current_z)
			
			# Chama a sua função de pintura que você quer debugar
			_paint_pixel_at_global_pos(global_pos, potencia)
			
			current_z += step_z
		current_x += step_x

	Manager.log_debug(\"Debug: Pintura do retângulo de mundo concluída.\")
	
	# IMPORTANTE: Força a atualização da textura para vermos o resultado
	result_texture.update(result_image)




### PARA SALVAR A IMAGEM DO CHÃO --------------------------------------------------------------

func _create_colored_image_for_export() -> Image:
	var colored_image = Image.create(resolution.x, resolution.y, false, Image.FORMAT_RGBA8)

	# Recria o gradiente de cores que você usa na UI
	var grad = Gradient.new()
	var critical_point_normalized = inverse_lerp(min_sinal_dbm, max_sinal_dbm, critical_sinal_dbm)
	critical_point_normalized = clamp(critical_point_normalized, 0.0, 1.0)
	grad.offsets = PackedFloat32Array([0.0, critical_point_normalized, 1.0])
	grad.colors = PackedColorArray([min_sinal_color, critical_sinal_color, max_sinal_color])
	
	# Itera por cada pixel da sua imagem de dados (result_image)
	for y in resolution.y:
		for x in resolution.x:
			# Pega o valor bruto de dBm da imagem original
			var sinal_recebido_dbm = result_image.get_pixel(x, y).r

			# Normaliza o sinal dBm para o intervalo 0.0-1.0
			var normalized_strength = inverse_lerp(min_sinal_dbm, max_sinal_dbm, sinal_recebido_dbm)
			normalized_strength = clamp(normalized_strength, 0.0, 1.0)

			# Usa o gradiente para obter a cor final
			var final_color = grad.sample(normalized_strength)
			
			# Define o pixel na nova imagem colorida
			colored_image.set_pixel(x, y, final_color)
	
	return colored_image


# NOVO: Função para salvar a imagem
func _input(event):
	if Input.is_action_just_pressed(\"ui_accept\"):
		if simular:
			print(\"Aguarde o cálculo terminar para salvar a imagem.\")
			return
		
		if result_image:
			# NOVO: Crie a imagem colorida para exportação
			var colored_image_to_save = _create_colored_image_for_export()
			
			var timestamp = Time.get_unix_time_from_system()
			var file_path = \"user://mapa_de_calor_exportado_%d.png\" % timestamp
			
			# Salve a imagem COLORIDA
			var error = colored_image_to_save.save_png(file_path)
			
			if error == OK:
				print(\"Imagem do mapa de calor COLORIDA salva em: \", file_path)
				OS.shell_open(ProjectSettings.globalize_path(\"user://\"))
			else:
				push_error(\"Falha ao salvar a imagem colorida! Código de erro: %d\" % error)
				
	# Só processa se estivermos num modo de edição
	if current_input_mode == InputMode.NONE:
		return

	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
		_handle_click(event.position)


# ==============================================================================
# CALLBACKS DA UI (Funções chamadas pelos sliders)
# ==============================================================================

func update_shader_visualization_parameters():
	# Função centralizada para atualizar todos os uniforms de visualização
	var material = _chao_parent.material_override as ShaderMaterial
	if not material: return
		
	material.set_shader_parameter(\"signal_map\", result_texture)
	material.set_shader_parameter(\"min_color\", min_sinal_color)
	material.set_shader_parameter(\"critical_color\", critical_sinal_color)
	material.set_shader_parameter(\"max_color\", max_sinal_color)
	material.set_shader_parameter(\"min_sinal_dbm\", min_sinal_dbm)
	material.set_shader_parameter(\"critical_sinal_dbm\", critical_sinal_dbm)
	material.set_shader_parameter(\"max_sinal_dbm\", max_sinal_dbm)
	
	update_color_bar()

func update_color_bar():
	# Atualiza a legenda com o gradiente de 3 cores
	var gradiente = GradientTexture1D.new()
	var grad = Gradient.new()

	# Calcula a posição normalizada do ponto crítico (entre 0.0 e 1.0)
	var critical_point = inverse_lerp(min_sinal_dbm, max_sinal_dbm, critical_sinal_dbm)
	critical_point = clamp(critical_point, 0.0, 1.0)

	# Define os pontos e cores do gradiente de uma vez
	# Isso é mais seguro que usar add_point e evita pontos padrão indesejados
	grad.offsets = PackedFloat32Array([0.0, critical_point, 1.0])
	grad.colors = PackedColorArray([min_sinal_color, critical_sinal_color, max_sinal_color])

	gradiente.gradient = grad
	#barra_de_cor.texture = gradiente # TESTANDO 23/01


func _refresh_ris_visualization(): # TESTANDO 23/01
	# Se ainda não temos simulação rodada, não faz nada
	if _baseline_power_map_watts.is_empty(): return
	
	if show_ris_effect:
		# Aplica o cálculo sobre a base
		_calculate_ris_beam_projection()
	else:
		# Restaura a base pura
		_power_map_watts = _baseline_power_map_watts.duplicate()
	
	# Atualiza a textura na GPU
	update_visual_texture_from_watts()

func interface_signal_config():
	# --- CONEXÃO COM A INTERFACE ---
	if interface_manager_path:
		var interface = get_node_or_null(interface_manager_path)
		if interface:
			# --- 1. IDA (Interface -> Motor) ---
			# Conecta o sinal do script da UI na função deste script
			interface.request_start.connect(_on_interface_request_start)
			interface.request_stop.connect(_on_interface_request_stop)
			interface.request_cancel.connect(_on_interface_request_cancel)
			interface.request_frequency_change.connect(_on_interface_freq_changed)
			interface.request_resolution_change.connect(_on_ui_resolution_changed)
			interface.request_heatmap_config.connect(_on_ui_heatmap_config_changed)
			interface.request_create_ris.connect(_on_interface_request_create_ris)
			interface.request_delete_ris.connect(_on_interface_request_delete_ris)
			interface.request_place_target.connect(_on_interface_request_place_target)

			
			# --- 2. VOLTA (Motor -> Interface) ---
			# Conectamos o NOSSO sinal na função DA INTERFACE
			# Verifique se a função existe na interface para evitar crash
			if interface.has_method(\"_on_simulation_progress_update\"):
				if not self.simulation_progress.is_connected(interface._on_simulation_progress_update):
					self.simulation_progress.connect(interface._on_simulation_progress_update)
			if interface.has_method(\"_on_simulation_stats_received\"):
				if not self.simulation_stats.is_connected(interface._on_simulation_stats_received):
					self.simulation_stats.connect(interface._on_simulation_stats_received)
			
			
			# Conecte as confirmações do Motor nas funções de UI da Interface
			if not self.ris_created_success.is_connected(interface._on_handshake_ris_created):
				self.ris_created_success.connect(interface._on_handshake_ris_created)
				
			if not self.ris_deleted_success.is_connected(interface._on_handshake_ris_deleted):
				self.ris_deleted_success.connect(interface._on_handshake_ris_deleted)
			
			if not interface.request_remove_target.is_connected(_on_interface_request_remove_target):
				interface.request_remove_target.connect(_on_interface_request_remove_target)
			
			print(\"Interface conectada com sucesso!\")
		else:
			push_error(\"Nó InterfaceManager não encontrado no caminho indicado!\")

func _on_interface_request_start():
	simular = true
	
func _on_interface_request_stop():
	simular = false

func _on_interface_request_cancel():
	simular = false
	start_simulation()

# --- FUNÇÃO CALLBACK (Ouvinte) ---
# Note que esta função PRECISA ter um argumento 'val', 
# pois o sinal envia um valor.
func _on_interface_freq_changed(val: float):
	print(\"Motor recebeu nova frequência: \", val)
	frequencia_mhz = val # Atualiza a variável interna do motor

	# Opcional: Se quiser atualizar em tempo real
	if simular: # Só reinicia se já estiver rodando
		start_simulation()

# 4. CRIE A FUNÇÃO QUE CALCULA TUDO
func _send_final_stats():
	var threshold_target = -70.0 # O valor que você pediu no relatório

	# Calcula Cobertura
	var covered_count = 0
	var total_valid_pixels = 0 # Opcional: descontar pixels fora do mapa se quiser

	for w in _power_map_watts:
		if w <= 0.0: continue # Ignora ruído zero absoluto
		var dbm = RFMath.watts_to_dbm(w)
		if dbm >= threshold_target:
			covered_count += 1
			
	var total_pixels = resolution.x * resolution.y
	var percent = (float(covered_count) / float(total_pixels)) * 100.0

	# Coleta os outros dados
	var current_time = Time.get_ticks_msec()
	var elapsed = current_time - _start_time_msec

	var stats = {
		\"coverage_percent\": percent,
		\"threshold\": threshold_target,
		\"elapsed_time\": elapsed,
		\"terrain_size\": _plane_size,
		\"frequency\": frequencia_mhz,
		\"antenna_count\": _tx_nodes.size()
	}

	emit_signal(\"simulation_stats\", stats)

func _on_ui_resolution_changed(new_res: Vector2i):
	print(\"Main: Recebi ordem de mudar resolução para \", new_res)
	
	# 1. PARE A SIMULAÇÃO (Segurança Crítica)
	# Se o loop tentar rodar enquanto estamos redimensionando, dá crash.
	var estava_rodando = is_processing() # ou sua variável is_running
	set_process(false) 
	
	# 2. Atualize a variável de resolução
	resolution = new_res
	
	# 3. REDIMENSIONE OS ARRAYS (A causa do seu erro na imagem)
	# O erro \"index out of bounds\" sumirá se o array tiver o tamanho certo.
	_power_map_watts.resize(resolution.x * resolution.y)
	_power_map_watts.fill(0.0)
	
	# 4. Atualize outras coisas dependentes (Texturas, GridMap, Câmera)
	# update_texture_size()
	
	# 5. Volte a rodar (se estava rodando antes)
	if estava_rodando:
		set_process(true)
		# Ou reinicie a simulação do zero
	
	if not result_image or result_image.get_size() != resolution:
		result_image = Image.create(resolution.x, resolution.y, false, Image.FORMAT_RF)
		result_texture = ImageTexture.create_from_image(result_image)

	# Inicializa com ruído de fundo
	result_image.fill(Color(min_sinal_dbm, 0, 0, 1))

	# Shader setup
	var material = ShaderMaterial.new()
	material.shader = load(\"res://Shaders/mapa_calor_shader_material.gdshader\")
	_chao_parent.material_override = material

# Chamada quando o usuário dá OK na janela de Configuração
func _on_ui_heatmap_config_changed(new_min: float, new_crit: float, new_max: float):
	print(\"Main: Atualizando visualização térmica para Min: %.1f, Crit: %.1f, Max: %.1f\" % [new_min, new_crit, new_max])
	
	# 1. Atualiza as variáveis
	min_sinal_dbm = new_min
	critical_sinal_dbm = new_crit
	max_sinal_dbm = new_max
	
	# 2. Atualiza variáveis dependentes da física (caso reinicie depois)
	min_watts = RFMath.dbm_to_watts(min_sinal_dbm)
	
	# 3. Atualiza o SHADER (Instantâneo)
	update_shader_visualization_parameters()
	
	# 4. Força atualização da barra de legenda (se não estiver incluso na função acima)
	update_color_bar()

func _on_interface_request_add_ris():
