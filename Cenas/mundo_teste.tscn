script/source = "# RayTracingEngine.gd
extends Node3D
# WARNING - CODIGO ATUAL - OK
# 22 / 11 / 2025
# GTA - UFRJ
# Motor Híbrido: Difração Determinística (Deygout/Scanner) + Reflexão Estocástica
#
# O simulador tem o objetivo de calcular a perda conforme a disposição das
# antenas e terreno. Para calcular a potencia no espaço, a perda tem que ser
# aplicada a partir da potencia da antena, exigindo especialização das perdas
# para cada antena e somar a potencia no ponto

enum SimulationMethod {
	V1_LOS_SIMPLE,      # Apenas Visada Direta (Rápido, sombras duras)
	V2_DIFFRACTION_ONLY,# Difração Vertical (Deygout), sem reflexão
	V3_HYBRID_FAST,     # Difração + Reflexão Simples (Splatting)
	V4_HYBRID_HI_FI     # Difração + Reflexão com Verificação de Obstrução
}

signal simulation_progress(percent: float)
signal simulation_stats(data: Dictionary)

# Sinais de resposta
signal ris_created_success(index: int, name: String)
signal ris_deleted_success(index: int)


@export_group(\"Referências de UI\")
@export var interface_manager_path: NodePath ## Arraste o nó \"InterfaceManager\" para cá

# --- Variáveis Exportadas (para ajustar no Editor) ---
@export_group(\"Cenário\")
@export var plane_to_paint: NodePath ## Arraste o nó do seu Plano para esta variável no Inspector do Godot
@export var transmitters: Array[NodePath] ## Arraste os NÓS de TX para esta variável
#@export var obstaculos_group_name: String = \"obstaculos\" # Nome do grupo dos prédios

@export_group(\"Método de Simulação\")
@export var use_spiral_calculation: bool = true # <--- NOVA VARIÁVEL GLOBAL
@export var simulation_mode: SimulationMethod = SimulationMethod.V3_HYBRID_FAST:
	set(val):
		simulation_mode = val
		if is_inside_tree(): start_simulation()

@export_group(\"Simulação - Performance & Qualidade\")
@export var resolution = Vector2i(256, 256) # Resolução da textura do resultado
@export var pixels_per_frame = 1024 # Velocidade da Fase 1
@export var total_rays_to_shoot: int = 500000
@export var total_reflection_rays = 5000 # Quantidade de raios SBR
@export var rays_per_frame: int = 4096 # Velocidade da Fase 2
@export var max_reflections: int = 5 # NOVO: Limite de \"quicadas\" do raio
@export var calculations_per_frame = 2048   # Quantos pixels calcular por frame (ajuste para performance)
@export var offset_colider: float = 0.01
@export var reflection_loss_db: float = 5.0: ## por enquanto é generalizada
	set(new_value):
		if reflection_loss_db == new_value: return
		reflection_loss_db = new_value
		if is_inside_tree(): # Garante que a simulação só rode se o nó estiver na cena
			start_simulation()

@export_group(\"Física de Rádio\")
@export var potencia_tx_dbm: float = 20.0
@export var frequencia_mhz: float = 2400.0 # OK
@export var min_sinal_dbm: float = -120.0 # 
@export var max_sinal_dbm: float = -30.0 # 
@export var path_loss_exponent: float = 2.8
@export var critical_sinal_dbm: float = -85.0

@export_group(\"Cores do Mapa de Calor\")
@export var min_sinal_color: Color = Color.BLUE
@export var critical_sinal_color: Color = Color.GREEN
@export var max_sinal_color: Color = Color.RED


@export_group(\"RIS - Física\")
@export var ris_target_gain_db: float = 35.0: 
	set(val):
		ris_target_gain_db = val
		# Se o RIS já existir na cena, atualiza a geometria na hora!
		if is_inside_tree() and active_ris:
			_update_ris_geometry_and_physics()
			if show_ris_effect: _refresh_ris_visualization()
@export var ris_physical_area_m2: float = 1.0 # Tamanho real da placa (ex: 1m x 1m)
@export var ris_efficiency: float = 0.9       # Perdas internas (90% reflete)
@export var target_spot_radius: float = 5.0   # Raio da área de foco no chão
@export var show_ris_effect: bool = false: # O Botão Mágico
	set(val):
		show_ris_effect = val
		if is_inside_tree(): _refresh_ris_visualization()

@export_group(\"Alvo - Geometria\")
@export_range(1.0, 50.0) var target_width_x: float = 2.0:
	set(val):
		target_width_x = val
		_update_target_visuals() # Atualiza na hora

@export_range(1.0, 50.0) var target_length_z: float = 2.0:
	set(val):
		target_length_z = val
		_update_target_visuals() # Atualiza na hora

@export_range(-180.0, 180.0) var target_rotation_y: float = 0.0:
	set(val):
		target_rotation_y = val
		_update_target_visuals() # Gira na hora
		
		

# Armazena o mapa \"puro\" sem a interferência do RIS
var _baseline_power_map_watts: PackedFloat32Array = []

## --- Referências para os Nós da UI (pegas automaticamente) ---
#@onready var slider_potencia: HSlider = $Control/VBoxContainer/Potencia/HSlider
#@onready var label_valor_potencia: Label = $Control/VBoxContainer/Potencia/Label2
#
#@onready var slider_freq: HSlider = $Control/VBoxContainer/Freq/HSlider
#@onready var label_valor_freq: Label = $Control/VBoxContainer/Freq/Label2
#
## O expoente não é usado no modelo de Ray Tracing LOS, mas mantemos pela UI
#@onready var slider_expoent: HSlider = $Control/VBoxContainer/Expoent/HSlider
#@onready var label_valor_expoent: Label = $Control/VBoxContainer/Expoent/Label2
#
#@onready var slider_min_sinal: HSlider = $Control/VBoxContainer/Min_sinal/HSlider
#@onready var label_valor_min_sinal: Label = $Control/VBoxContainer/Min_sinal/Label2
#
#@onready var slider_crit_sinal: HSlider = $Control/VBoxContainer/Crit_sinal/HSlider
#@onready var label_valor_crit_sinal: Label = $Control/VBoxContainer/Crit_sinal/Label2
#
#@onready var slider_max_sinal: HSlider = $Control/VBoxContainer/Max_sinal/HSlider
#@onready var label_valor_max_sinal: Label = $Control/VBoxContainer/Max_sinal/Label2
#
#@onready var barra_de_cor: TextureRect = $Control/VBoxContainer/cor_calor/TextureRect
#@onready var label_legenda_min: Label = $Control/VBoxContainer/cor_calor/Label
#@onready var label_legenda_max: Label = $Control/VBoxContainer/cor_calor/Label2


# --- Variáveis Internas de Controle ---
enum SimState { IDLE, PHASE_1_DIRECT, PHASE_2_REFLECTION, FINISHED }
var current_state = SimState.IDLE

# para colocar areas do RIS com o mouse
enum InputMode { NONE, PLACING_RIS, PLACING_TARGET }
var current_input_mode = InputMode.NONE 

var ris_scene = preload(\"res://Cenas/Componentes/ris_module.tscn\") # Ajuste o caminho!
var active_ris: Node3D = null

# --- Substitua as variáveis de alvo antigas por estas ---
var active_targets: Array[Node3D] = [] # Lista que guarda as caixas (Node3D)
var active_ris_weight: float = 1.0     # O peso atual (1.0, 0.5, 0.33...)

# Lista para guardar as instâncias reais dos RIS
var _active_ris_nodes: Array[Node3D] = [] # TESTANDO 29/01/26

var ris_enabled: bool = false # Controla o cálculo
var target_visual: MeshInstance3D = null # Para guardar a caixa verde do alvo

# Configuração do RIS (Ganho artificial para o protótipo)
var ris_gain_db = 5.0

# Referência para o TX (Assumindo que é o primeiro da lista para o protótipo)
var tx_ref: Node3D # WARNING provavelmente repetida...



var _plane_size: Vector2
var _chao_node: Node3D
var _chao_body: RID
var _chao_parent: Node3D # Será o MeshInstance3D \"ChaoMapaDeCalor\"
var _chao_static_body: StaticBody3D
var last_collider_rid
var _space_state: PhysicsDirectSpaceState3D

# Cache e Dados
var _tx_nodes: Array[Node3D] = []
var _tx_rids: Array[RID] = []
var _aabb_cache: Dictionary = {}

# Buffer de Dados (O Segredo da Soma de Potência)
# Armazena a potência acumulada em WATTS para cada pixel
var _current_pixel_idx: int = 0

# Imagem final
var result_image: Image
var result_texture: ImageTexture
var _power_map_watts: PackedFloat32Array


var _tx_parents: Array[Node3D] = [] # Lista de nós dos TXs
var _tx_static_bodies: Array[RID] = [] # Lista dos RIDs dos colliders dos TXs

var tx_index_LOS = 0

var _current_pixel = Vector2i(0, 0)
#var _is_calculating_pixels = false # TESTANDO 27/01/26
#var _is_calculating_rays = false # TESTANDO 27/01/26
var simular = false

# variaveis de simulacao
var min_watts = 0.0
var lambda_m = 1.0


var _start_time_msec: int = 0

func _ready():	
	# _chao_parent aqui vai apontar para o seu MeshInstance3D
	_chao_parent = get_node_or_null(plane_to_paint)
	
	# Pega as referências dos nós PAIS a partir dos NodePaths
	if transmitters.is_empty():
		push_error(\"Nenhum Transmissor (TX) foi definido no array 'transmitters'!\")
		return
	
	for tx_path in transmitters:
		var tx_node = get_node_or_null(tx_path)
		if not tx_node:
			push_error(\"Nó de TX não encontrado no caminho: %s\" % tx_path)
			continue
			
		var tx_collider = tx_node.get_node_or_null(\"MeshInstance3D/StaticBody3D\")
		if not tx_collider:
			push_error(\"Não foi possível encontrar 'MeshInstance3D/StaticBody3D' no TX: %s\" % tx_node.name)
			continue
			
		_tx_parents.append(tx_node)
		_tx_static_bodies.append(tx_collider.get_rid())
		
		_tx_nodes.append(tx_node)
		_tx_rids.append(tx_collider.get_rid())
	
	if _tx_parents.is_empty():
		push_error(\"Nenhum TX válido foi carregado. Simulação cancelada.\")
		return
	
	if _chao_parent.has_node(\"StaticBody3D\"):
		_chao_static_body = _chao_parent.get_node(\"StaticBody3D\")
	
	else:
		push_error(\"Chão sem StaticBody3D filho direto.\")
		return
	
	_space_state = get_world_3d().direct_space_state
	
	# CORREÇÃO 3: Como _chao_parent JÁ É o MeshInstance, usamos ele diretamente
	var plane_mesh = _chao_parent.mesh as PlaneMesh
	if plane_mesh:
		_plane_size = plane_mesh.size
	
	else:
		push_error(\"O nó 'plane_to_paint' não contém um PlaneMesh!\")
		return
	
	# PRE-CALCULO: Cachear todas as AABBs dos obstáculos estáticos
	# Isso evita percorrer a árvore de nós durante a simulação
	print(\"Iniciando cache de AABBs...\")
	
	_scan_obstacles_recursive(get_tree().root)
	print(\"Cache concluído. Objetos cacheados: \", _aabb_cache.size())
	
	interface_signal_config()
	_spawn_target_visual(Vector3(42.318, 0.000, -793.291)) # TESTANDO
	start_simulation()


func _scan_obstacles_recursive(node):
	if node is StaticBody3D:
		var aabb = _calculate_aabb_logic(node)
		if aabb.size != Vector3.ZERO:
			_aabb_cache[node.get_rid()] = aabb
	for child in node.get_children():
		_scan_obstacles_recursive(child)

# ==============================================================================
# LOOP PRINCIPAL (_PROCESS)
# ==============================================================================

func start_simulation():
	if not is_instance_valid(_chao_parent): return
	print(\"Iniciando simulação Híbrida (Scanner + RayShooting)...\")
	
	_current_pixel = Vector2i(0, 0)
	_power_map_watts.resize(resolution.x * resolution.y)
	_power_map_watts.fill(0.0)
	
	if not result_image or result_image.get_size() != resolution:
		result_image = Image.create(resolution.x, resolution.y, false, Image.FORMAT_RF)
		result_texture = ImageTexture.create_from_image(result_image)
	
	# Inicializa com ruído de fundo
	result_image.fill(Color(min_sinal_dbm, 0, 0, 1))
	
	# Shader setup
	var material = ShaderMaterial.new()
	material.shader = load(\"res://Shaders/mapa_calor_shader_material.gdshader\")
	_chao_parent.material_override = material
	update_shader_visualization_parameters()
	
	#_is_calculating_pixels = true
	#_is_calculating_rays = true
	
	# definicao das variaveis globais
	lambda_m = RFMath.get_lambda_m(frequencia_mhz)
	min_watts = RFMath.dbm_to_watts(min_sinal_dbm)
	
	_start_time_msec = Time.get_ticks_msec()

	
func _process(_delta):
	if not simular: return
	
	#if not _is_calculating_pixels: return
	
	var calculated = 0
	var start_watts = RFMath.dbm_to_watts(potencia_tx_dbm)
	
	while calculated < pixels_per_frame and _current_pixel.y < resolution.y:
		
		# 1. Alvo (Centro do Pixel)
		var target_pos_world = _pixel_to_world(_current_pixel)
		#target_pos_world.y += 0.25 # TESTE BIAS de altura
		
		for i in range(_tx_nodes.size()):
			var tx_node = _tx_nodes[i]
			var tx_rid = _tx_rids[i]
			
			var tx_pos = tx_node.global_position
			var dist_total = tx_pos.distance_to(target_pos_world)
			var dir_to_pixel = (target_pos_world - tx_pos).normalized()
			
			# 2. Chama a função principal de cálculo
			_calculate_pixel_signal(tx_pos, dir_to_pixel, dist_total, start_watts, [tx_rid], 0)
		
		_current_pixel.x += 1
		if _current_pixel.x >= resolution.x:
			_current_pixel.x = 0
			_current_pixel.y += 1
			
			# --- ATUALIZAÇÃO DE PROGRESSO (Por Linha) ---
			# Calculamos a cada fim de linha para não sobrecarregar com sinais
			var progress = (float(_current_pixel.y) / float(resolution.y)) * 100.0
			emit_signal(\"simulation_progress\", progress)
			_send_final_stats()
			
		calculated += 1
		
		
	if _current_pixel.y >= resolution.y:
		#_is_calculating_pixels = false
		print(\"Cálculo concluído.\")
		emit_signal(\"simulation_progress\", 100.0) # Garante 100% no final
		simular = false
		
		# 1. SALVA O BACKUP (O mapa \"limpo\")
		_baseline_power_map_watts = _power_map_watts.duplicate()
		
		# 2. Se o botão de RIS estiver ativado, calcula a \"sobra\" agora
		if show_ris_effect and ris_enabled:
			_calculate_ris_beam_projection()
	
	update_visual_texture_from_watts()

# funcoes para geracao de RIS ======================================================================

# Essa função roda instantaneamente (sem raytracing) para projetar o ganho do RIS
# Essa função roda instantaneamente (sem raytracing) para projetar o ganho do RIS
# Essa função roda instantaneamente (sem raytracing) para projetar o ganho do RIS
# Essa função roda instantaneamente (sem raytracing) para projetar o ganho do RIS
func _calculate_ris_beam_projection():
	# 1. Verificações de Segurança
	if active_targets.is_empty() or not active_ris or _baseline_power_map_watts.is_empty():
		return
	if _tx_nodes.is_empty():
		return

	# --- SETUP GEOMÉTRICO ---
	var ris_pos = active_ris.global_position
	var ris_normal = -active_ris.global_transform.basis.z.normalized()
	var tx_ref = _tx_nodes[0]
	var tx_pos = tx_ref.global_position
	
	# Calcula o Centro dos Alvos
	var center_target = Vector3.ZERO
	for t in active_targets: center_target += t.global_position
	center_target /= float(active_targets.size())

	# --- FÍSICA PARTE 1: ÂNGULOS (PERDA DE SCAN) ---
	var vec_tx_ris = ris_pos - tx_pos
	var dist_tx_ris = vec_tx_ris.length()
	var dir_tx_ris_in = vec_tx_ris.normalized()
	var dir_ris_target_out = (center_target - ris_pos).normalized()

	# Fatores de perda angular (Lei do Cosseno)
	var incidence_factor = abs(dir_tx_ris_in.dot(ris_normal))
	var departure_factor = abs(dir_ris_target_out.dot(ris_normal))
	var total_angular_efficiency = incidence_factor * departure_factor
	
	if total_angular_efficiency < 0.001:
		return

	# --- FÍSICA PARTE 2: ÁREA EFETIVA (A CORREÇÃO) ---
	
	var lambda = RFMath.get_lambda_m(frequencia_mhz)
	var tx_watts = RFMath.dbm_to_watts(potencia_tx_dbm)
	
	# Aqui calculamos a área REAL necessária para ter esse Ganho (dB)
	# Aperture Theory: Area = (G_linear * lambda^2) / (4 * PI)
	var ris_gain_linear = RFMath.db_to_linear(ris_gain_db)
	var area_efetiva_celulas = (ris_gain_linear * pow(lambda, 2.0)) / (4.0 * PI)
	
	# Densidade de Potência chegando no RIS (Watts/m2)
	var power_density_at_ris_face = tx_watts / (4.0 * PI * pow(dist_tx_ris, 2.0))
	
	# Potência Total Capturada e Refletida
	# P = Densidade * Area_Efetiva * Eficiencia_Angular * Eficiencia_Ohmica
	var power_captured_watts = power_density_at_ris_face * area_efetiva_celulas * total_angular_efficiency * ris_efficiency
	
	# Debug Confirmando a Área Calculada
	#print(\"--- RIS PHYSICS REPORT ---\")
	#print(\"Ganho Alvo: %.1f dB | Freq: %.0f MHz\" % [ris_gain_db, frequencia_mhz])
	#print(\"Área Efetiva Calculada: %.4f m²\" % area_efetiva_celulas)
	#print(\"Potência Entregue: %.2e Watts\" % power_captured_watts)

	# --- FÍSICA PARTE 3: DISTRIBUIÇÃO (O FOCO) ---
	var spot_area_m2 = PI * pow(target_spot_radius, 2.0)
	var power_density_at_target = power_captured_watts / spot_area_m2
	
	# --- RENDERIZAÇÃO ---
	_power_map_watts = _baseline_power_map_watts.duplicate()
	
	var pixel_size_m = _plane_size.x / float(resolution.x)
	var radius_in_pixels = int(target_spot_radius / pixel_size_m) + 2
	
	var local_center = _chao_parent.to_local(center_target)
	var center_uv_x = (local_center.x / _plane_size.x) + 0.5
	var center_uv_y = (local_center.z / _plane_size.y) + 0.5
	var center_px_x = int(center_uv_x * resolution.x)
	var center_px_y = int(center_uv_y * resolution.y)
	
	var start_x = max(0, center_px_x - radius_in_pixels)
	var end_x = min(resolution.x, center_px_x + radius_in_pixels)
	var start_y = max(0, center_px_y - radius_in_pixels)
	var end_y = min(resolution.y, center_px_y + radius_in_pixels)
	
	var pixel_area_m2 = pixel_size_m * pixel_size_m
	var watts_per_pixel = power_density_at_target * pixel_area_m2
	
	for y in range(start_y, end_y):
		for x in range(start_x, end_x):
			var idx = y * resolution.x + x
			
			var uv_x = (float(x) + 0.5) / resolution.x
			var uv_y = (float(y) + 0.5) / resolution.y
			var local_x = (uv_x - 0.5) * _plane_size.x
			var local_z = (uv_y - 0.5) * _plane_size.y
			var pixel_pos_world = _chao_parent.to_global(Vector3(local_x, 0.0, local_z))
			
			var dist_to_center = pixel_pos_world.distance_to(center_target)
			
			if dist_to_center <= target_spot_radius:
				_power_map_watts[idx] += watts_per_pixel

	print(\"RIS: Energia redistribuída (Baseada em Ganho/Área) com sucesso.\")


func _calculate_ris_properties(target_gain_db: float, freq_mhz: float) -> Dictionary:
	var lambda = RFMath.get_lambda_m(freq_mhz)
	var cell_size = lambda / 2.0 # Tamanho padrão do elemento
	
	# Conversão dB -> Linear
	var target_gain_linear = RFMath.db_to_linear(target_gain_db)
	
	# Fórmula Simplificada de Diretividade para Array Planar Uniforme:
	# D ~= 4 * PI * Area / lambda^2
	# Area = N_total * cell_size^2
	# Substituindo cell_size = lambda/2:
	# D ~= PI * N_total
	
	# Logo, N_total ~= D / PI
	var total_cells = target_gain_linear / PI
	
	# Vamos assumir um RIS quadrado (N = M)
	var side_cells = int(sqrt(total_cells))
	if side_cells < 2: side_cells = 2 # Mínimo 2x2
	
	var N = side_cells
	var M = side_cells
	var total_N = N * M
	
	# Recalcula o tamanho físico final
	var width_m = N * cell_size
	var height_m = M * cell_size
	var physical_area = width_m * height_m
	
	# Recalcula o ganho real atingido (para ser honesto)
	var real_gain_linear = PI * total_N
	var real_gain_db = linear_to_db(real_gain_linear) # Precisa ter essa função no RFMath ou fazer aqui
	
	return {
		\"N\": N,
		\"M\": M,
		\"width_m\": width_m,
		\"height_m\": height_m,
		\"cell_size\": cell_size,
		\"real_gain_db\": real_gain_db,
		\"physical_area\": physical_area
	}

# Helper rápido se não tiver no RFMath
func linear_to_db(lin): return 10.0 * log(lin) / log(10.0)


func _update_ris_geometry_and_physics():
	if not active_ris: return
	
	# 1. Recalcula a matemática baseada no novo Ganho (dB)
	var props = _calculate_ris_properties(ris_target_gain_db, frequencia_mhz)
	
	# 2. Atualiza as variáveis físicas globais
	ris_physical_area_m2 = props[\"physical_area\"]
	ris_gain_db = props[\"real_gain_db\"]
	
	# 3. Aplica a nova escala visualmente (O EFEITO WOW)
	# Mantemos o Z (espessura) em 5cm
	var tween = create_tween()
	tween.tween_property(active_ris, \"scale\", Vector3(props[\"width_m\"], props[\"height_m\"], 0.05), 0.2)
	
	print(\"RIS Atualizado: %.1f dB -> Tamanho: %.2fx%.2f m (%dx%d celulas)\" % 
		[ris_gain_db, props[\"width_m\"], props[\"height_m\"], props[\"N\"], props[\"M\"]])



func _spawn_or_move_ris(pos: Vector3):
	# Se não tiver TX, aborta
	if _tx_nodes.is_empty(): 
		print(\"Erro: Sem TX na cena para orientar o RIS\")
		return

	# Instancia se não existir
	if active_ris == null:
		active_ris = ris_scene.instantiate()
		add_child(active_ris)
	
	# Posiciona (Levanta um pouco do chão para ser o centro da TV)
	active_ris.global_position = pos + Vector3(0, 1.5, 0) 
	tx_ref = _tx_nodes[0] # Pega o primeiro TX como referência

#func _orient_ris_to_target():
	#if not active_ris or not tx_ref: return
	#
	#var ris_pos = active_ris.global_position
	#var tx_pos = tx_ref.global_position
	#
	## 1. Vetor chegando do TX (Do TX para o RIS)
	## Na verdade, para reflexão, pensamos no vetor SAINDO do RIS para o TX e SAINDO do RIS para o Alvo
	#var dir_to_tx = (tx_pos - ris_pos).normalized()
	#var dir_to_target = (target_point - ris_pos).normalized()
	#
	## 2. A Bissetriz (O vetor Normal ideal)
	## A soma de dois vetores normalizados dá a direção média (bissetriz)
	#var ideal_normal = (dir_to_tx + dir_to_target).normalized()
	#
	## 3. Orientar o RIS
	## O \"look_at\" aponta o eixo -Z (frente) para um alvo.
	## Se o RIS for uma placa, o eixo Z é a Normal. 
	## Então queremos olhar na direção da Normal calculada.
	#
	## Como look_at olha para um PONTO, somamos a normal à posição atual
	#active_ris.look_at(ris_pos + ideal_normal, Vector3.UP)
	#
	## DEBUG VISUAL (Opcional: Desenha linhas para conferir)
	## DrawLine3D.draw_ray(ris_pos, dir_to_tx * 5, Color.RED)    # Para TX
	## DrawLine3D.draw_ray(ris_pos, dir_to_target * 5, Color.GREEN) # Para Alvo
	## DrawLine3D.draw_ray(ris_pos, ideal_normal * 5, Color.BLUE)   # Normal


func _handle_click(screen_pos: Vector2):
	# Raycast da Câmera para o Mundo
	var camera = get_viewport().get_camera_3d()
	var from = camera.project_ray_origin(screen_pos)
	var to = from + camera.project_ray_normal(screen_pos) * 2000.0 # Raio longo
	
	var space_state = get_world_3d().direct_space_state
	var query = PhysicsRayQueryParameters3D.create(from, to)
	# query.collide_with_areas = true # Descomente se o chão for Area3D
	
	var result = space_state.intersect_ray(query)
	
	if result:
		var hit_pos = result.position
		
		match current_input_mode:
			InputMode.PLACING_RIS:
				# AQUI ESTÁ A MUDANÇA: Chama a função que calcula E cria
				_create_ris_complete(hit_pos)
				
				# Desliga o modo imediatamente
				current_input_mode = InputMode.NONE
				print(\"Motor: RIS criado e posicionado.\")
				
			InputMode.PLACING_TARGET:
							# Agora chamamos a função que lida com a lista
							_spawn_target_visual(hit_pos)
							_orient_ris_automatically()
							
							# DECISÃO DE DESIGN: 
							# Se você quiser adicionar VÁRIOS, comente a linha abaixo.
							# Se quiser adicionar UM por vez e sair, mantenha.
							# Por enquanto, vou deixar você adicionar UM e sair, para manter o controle.
							current_input_mode = InputMode.NONE 
							print(\"Alvo posicionado. Para adicionar outro, clique no botão 'Adicionar Alvo' novamente.\")

# 3. Instancia o RIS
